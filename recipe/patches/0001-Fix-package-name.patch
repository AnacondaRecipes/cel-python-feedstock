From 5dd4732b3c42662765cc598848523810c1de8f21 Mon Sep 17 00:00:00 2001
From: Mikolaj Gralczyk <mgralczyk@anaconda.com>
Date: Wed, 17 Dec 2025 18:31:32 +0100
Subject: [PATCH] Fix package name

In PYPI, this package is named `cel-python`, not `celpy`.
This is fixed in version 0.3.0
---
 pyproject.toml | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index e337476..d98a3fb 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -25,7 +25,7 @@ skip = [
   ]
 
 [tool.poetry]
-name = "celpy"
+name = "cel-python"
 version = "0.2.0"
 description = "Pure Python implementation of Google Common Expression Language"
 authors = ["S. Lott <slott56@gmail.com>"]
@@ -35,6 +35,7 @@ classifiers = [
   "Development Status :: 4 - Beta",
   "Programming Language :: Python"
 ]
+packages = [{include = "celpy", from = "src"}]
 
 [tool.poetry.dependencies]
 python = "^3.8"
-- 
